---
const { siswa } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a 
  href={`${base}/anggota/${siswa.slug}`}
  class="block border border-charcoal-600 p-4 hover:border-accent transition-colors text-center"
>
  <img 
    src={`${base}/${siswa.image}`} 
    alt={siswa.nama}
    class="w-20 h-20 mx-auto object-cover border border-charcoal-600"
  />
  <p class="mt-2 font-medium text-charcoal-100 text-sm">{siswa.nama}</p>
</a>