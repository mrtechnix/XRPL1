---
import "../styles/global.css";
---

<nav class="navbar bg-charcoal-900 border-b border-charcoal-600 px-4 py-3 sm:px-6 md:px-8 fixed z-2">
  <!-- Bagian Kiri: Logo & Judul -->
  <div class="navbar-start">
    <img src="/logo.jpeg" alt="Logo X RPL 1" width="50" height="50" class="rounded-full shadow-md border-2 border-charcoal-600" />
    <h1 class="text-xl font-bold text-charcoal-100 tracking-wide ml-3">X RPL 1 SkensaPas</h1>
  </div>

  <!-- Menu Desktop (muncul di layar lebar) -->
  <div class="navbar-end hidden lg:flex">
    <ul class="menu menu-horizontal px-1 text-charcoal-100 font-medium gap-1">
      <li><a href="#" class="hover:text-accent hover:bg-charcoal-700 rounded-md">Beranda</a></li>
      <li><a href="#" class="hover:text-accent hover:bg-charcoal-700 rounded-md">Anggota</a></li>
      <li><a href="#" class="hover:text-accent hover:bg-charcoal-700 rounded-md">Galeri</a></li>
      <li><a href="#" class="hover:text-accent hover:bg-charcoal-700 rounded-md">Kontak</a></li>
    </ul>
  </div>

  <!-- Menu Mobile (dropdown di kanan) -->
  <div class="navbar-end lg:hidden">
    <div class="dropdown dropdown-end">
      <label tabindex="0" class="btn btn-ghost btn-circle text-charcoal-100">
        <!-- Ikon Hamburger -->
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 p-2 shadow bg-charcoal-800 rounded-box w-52 text-charcoal-100 font-medium">
        <li><a href="#" class="hover:text-accent hover:bg-charcoal-700">Beranda</a></li>
        <li><a href="#" class="hover:text-accent hover:bg-charcoal-700">Anggota</a></li>
        <li><a href="#" class="hover:text-accent hover:bg-charcoal-700">Galeri</a></li>
        <li><a href="#" class="hover:text-accent hover:bg-charcoal-700">Tentang kita</a></li>
      </ul>
    </div>
  </div>
</nav>