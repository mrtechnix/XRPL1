---
import "../styles/global.css";
const base = import.meta.env.BASE_URL;

// Dapatkan path aktif tanpa trailing slash
const currentPath = Astro.url.pathname.replace(/\/$/, "");

const links = [
  { href: `${base}/`, label: "Beranda" },
  { href: `${base}/tentang`, label: "Tentang" },
  { href: `${base}/anggota`, label: "Anggota" },
  { href: `${base}/galeri`, label: "Galeri" },
  { href: `${base}/kontak`, label: "Kontak" },
];
---

<nav class="bg-charcoal-900 border-b border-charcoal-600 px-4 py-3 fixed top-0 left-0 w-full z-20 flex justify-between items-center">
  <!-- Logo & Judul -->
  <div class="flex items-center shrink-0">
    <img 
      src={`${base}/logo.jpeg`} 
      alt="Logo X RPL 1" 
      width="40" height="40" 
      class="w-10 h-10 object-cover rounded-sm border border-charcoal-600" 
    />
    <h1 class="ml-2 text-lg font-bold text-charcoal-100 truncate">
      X RPL 1 SkensaPas
    </h1>
  </div>

  <!-- Desktop Menu -->
  <div class="hidden lg:flex items-center gap-2">
    {links.map(link => {
      const linkPath = new URL(link.href, Astro.url).pathname.replace(/\/$/, "");
      const isActive = currentPath === linkPath;
      return (
        <a 
          href={link.href}
          class={`px-4 py-2 transition-colors ${
            isActive 
              ? "text-accent border-b-2 border-accent" 
              : "text-charcoal-100 hover:text-accent"
          }`}
        >
          {link.label}
        </a>
      );
    })}
  </div>

  <!-- Mobile Menu (dipertahankan) -->
  <div class="lg:hidden">
    <!-- Burger button & dropdown sama seperti sebelumnya, tanpa shadow -->
    <!-- Kode interaktif tetap bisa digunakan dari file lama -->
  </div>
</nav>

<!-- Script burger menu (dari versi awal) tetap dapat dipertahankan di sini -->
<script>
  // ... (salin kode setupBurgerMenu dari file asli)
</script>