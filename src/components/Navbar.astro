---
import "../styles/global.css";
const base = import.meta.env.BASE_URL;
---

<nav class="navbar bg-charcoal-900 border-b border-charcoal-600 px-4 py-3 sm:px-6 md:px-8 fixed top-0 left-0 w-full z-20 flex justify-between items-center">
  <!-- Bagian Kiri: Logo & Judul -->
  <div class="navbar-start flex items-center shrink-0">
    <img 
      src={`${base}logo.jpeg`} 
      alt="Logo X RPL 1" 
      width="50" 
      height="50" 
      class="w-10 h-10 sm:w-12 sm:h-12 rounded-full shadow-md border-2 border-charcoal-600 shrink-0 object-cover" 
    />
    <h1 class="text-base sm:text-lg md:text-xl font-bold text-charcoal-100 tracking-wide ml-2 sm:ml-3 truncate">
      X RPL 1 SkensaPas
    </h1>
  </div>

  <!-- Menu Desktop -->
  <div class="navbar-end hidden lg:flex items-center justify-end">
    <ul class="menu menu-horizontal px-1 text-charcoal-100 font-medium gap-2 xl:gap-6 flex items-center">
      <li><a href="#" class="hover:text-accent hover:bg-charcoal-700 rounded-md transition-colors">Beranda</a></li>
      <li><a href="#" class="hover:text-accent hover:bg-charcoal-700 rounded-md transition-colors">Anggota</a></li>
      <li><a href="#" class="hover:text-accent hover:bg-charcoal-700 rounded-md transition-colors">Galeri</a></li>
      <li><a href="#" class="hover:text-accent hover:bg-charcoal-700 rounded-md transition-colors">Kontak</a></li>
    </ul>
  </div>

  <!-- Menu Mobile (Interactive Burger) -->
  <div class="navbar-end lg:hidden flex items-center justify-end relative">
    <!-- Tombol Burger Toggle -->
    <button 
      id="burger-btn"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      class="btn btn-ghost btn-circle text-charcoal-100 flex items-center justify-center focus:outline-none"
    >
      <!-- Icon Burger (Tampil saat tertutup) -->
      <svg id="burger-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      
      <!-- Icon Silang 'X' (Tampil saat terbuka) -->
      <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Menu Dropdown Mobile -->
    <div 
      id="mobile-menu"
      class="hidden absolute right-0 top-12 mt-2 w-52 bg-charcoal-800 rounded-box shadow-xl border border-charcoal-600 z-30 p-2"
    >
      <ul class="menu menu-sm text-charcoal-100 font-medium">
        <li><a href="#" class="mobile-link hover:text-accent hover:bg-charcoal-700 py-2 rounded-md">Beranda</a></li>
        <li><a href="#" class="mobile-link hover:text-accent hover:bg-charcoal-700 py-2 rounded-md">Anggota</a></li>
        <li><a href="#" class="mobile-link hover:text-accent hover:bg-charcoal-700 py-2 rounded-md">Galeri</a></li>
        <li><a href="#" class="mobile-link hover:text-accent hover:bg-charcoal-700 py-2 rounded-md">Kontak</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- Logic Interaktif untuk Burger Menu -->
<!-- Logic Interaktif untuk Burger Menu -->
<script>
  function setupBurgerMenu() {
    const burgerBtn = document.getElementById('burger-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const burgerIcon = document.getElementById('burger-icon');
    const closeIcon = document.getElementById('close-icon');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    // Early return jika salah satu elemen tidak ditemukan
    if (!burgerBtn || !mobileMenu || !burgerIcon || !closeIcon) return;

    function toggleMenu() {
      // Menggunakan Optional Chaining (?.) agar TypeScript 100% yakin aman dari null
      const isOpen = !mobileMenu?.classList.contains('hidden');
      
      if (isOpen) {
        // Tutup menu
        mobileMenu?.classList.add('hidden');
        burgerIcon?.classList.remove('hidden');
        burgerIcon?.classList.add('block');
        closeIcon?.classList.remove('block');
        closeIcon?.classList.add('hidden');
        burgerBtn?.setAttribute('aria-expanded', 'false');
      } else {
        // Buka menu
        mobileMenu?.classList.remove('hidden');
        burgerIcon?.classList.remove('block');
        burgerIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        closeIcon?.classList.add('block');
        burgerBtn?.setAttribute('aria-expanded', 'true');
      }
    }

    // Toggle saat tombol burger diklik
    burgerBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    // Otomatis tutup menu jika pengguna mengklik tautan menu
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (!mobileMenu.classList.contains('hidden')) {
          toggleMenu();
        }
      });
    });

    // Otomatis tutup menu jika pengguna mengklik area luar navbar
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      if (!mobileMenu.contains(target) && !burgerBtn.contains(target)) {
        if (!mobileMenu.classList.contains('hidden')) {
          toggleMenu();
        }
      }
    });
  }

  // Jalankan saat halaman dimuat
  document.addEventListener('DOMContentLoaded', setupBurgerMenu);
  document.addEventListener('astro:page-load', setupBurgerMenu);
</script>