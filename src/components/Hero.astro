---
import "../styles/global.css";
---

<!-- Container utama dengan background image -->
<div 
  class="relative w-full h-screen bg-cover bg-center flex items-center justify-center" 
  style="background-image: url('/fotbar.jpeg');"
>
  <!-- Overlay gelap agar teks kontras -->
  <div class="absolute inset-0 bg-black/60"></div>

  <!-- Teks di atas overlay -->
  <div class="relative z-10 text-center px-4">
    <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight" style="font-family: 'Poppins', sans-serif;">
      Welcome to <span class="text-accent">X RPL 1</span>
    </h1>
    <p class="mt-4 text-lg md:text-xl text-gray-300 max-w-2xl mx-auto">
      Tempat kami berkarya, berkompetisi, dan mengukir prestasi.
    </p>
  </div>
</div>