---
import Layout from "../layouts/Layout.astro";
import SiswaCard from "../components/SiswaCard.astro";
import siswa from "../components/siswa.json";
---

<Layout>
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-accent mb-8 text-center">Anggota Kelas</h1>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
      {siswa.map((s, index) => (
        <div data-aos="fade-up" data-aos-delay={index * 50}>
          <SiswaCard siswa={s} />
        </div>
      ))}
    </div>
  </section>
</Layout>