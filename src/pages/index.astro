---
import Layout from "../layouts/Layout.astro";
import SiswaCard from "../components/SiswaCard.astro";
import siswa from "../components/siswa.json";
const base = import.meta.env.BASE_URL;
---

<Layout>
  <!-- Hero -->
  <section 
    class="relative h-screen flex items-center justify-center bg-cover bg-center" 
    style={`background-image: url('${base}/fotbar.jpeg');`}
  >
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 text-center px-4">
      <h1 class="text-5xl md:text-7xl font-bold text-white">
        X <span class="text-accent">RPL 1</span>
      </h1>
      <p class="mt-4 text-xl text-gray-300">Kreatif, Solid, Siap Berkarya</p>
    </div>
  </section>

  <!-- Statistik Singkat -->
  <section class="py-12 px-4 max-w-4xl mx-auto">
    <div class="grid grid-cols-3 gap-4 text-center">
      <div class="border border-charcoal-600 p-4">
        <span class="block text-2xl font-bold text-accent">36</span>
        <span class="text-sm">Siswa</span>
      </div>
      <div class="border border-charcoal-600 p-4">
        <span class="block text-2xl font-bold text-accent">1</span>
        <span class="text-sm">Wali Kelas</span>
      </div>
      <div class="border border-charcoal-600 p-4">
        <span class="block text-2xl font-bold text-accent">2026/2027</span>
        <span class="text-sm">Tahun Ajaran</span>
      </div>
    </div>
  </section>

  <!-- Pratinjau Anggota -->
  <section class="py-12 px-4 max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-accent text-center mb-8">Beberapa Anggota</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {siswa.slice(0, 4).map(s => <SiswaCard siswa={s} />)}
    </div>
    <div class="text-center mt-6">
      <a href={`${base}/anggota`} class="text-accent hover:underline text-lg">
        Lihat Semua &rarr;
      </a>
    </div>
  </section>
</Layout>