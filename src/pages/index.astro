---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import siswa from "../components/siswa.json";

const base = import.meta.env.BASE_URL;
---

<Layout>
  <Navbar />

  <!-- Hero Section -->
  <section
    class="relative h-screen flex items-center justify-center bg-cover bg-center"
    style={`background-image: url('${base}/fotbar.jpeg');`}
    data-aos="zoom-in"
  >
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 text-center px-4">
      <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight">
        Welcome to <span class="text-accent">X RPL 1</span>
      </h1>
      <p class="mt-4 text-lg md:text-xl text-gray-300">
        Kreatif, Solid, Siap Berkarya
      </p>
    </div>
  </section>

  <!-- Tentang Kelas -->
  <section class="py-16 px-4 max-w-4xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-charcoal-100">Tentang Kami</h2>
    <p class="mt-4 text-charcoal-300 leading-relaxed">
      X RPL 1 adalah bagian dari jurusan Rekayasa Perangkat Lunak di SMK Negeri 1 Pasuruan. 
      Kami berjumlah 35 siswa dengan semangat belajar tinggi, dibimbing oleh Ibu Kholifatul Azizah. 
      Kebersamaan dan kolaborasi adalah fondasi utama kami.
    </p>
    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4 text-charcoal-100">
      <div class="p-4 bg-charcoal-800 rounded-lg" data-aos="flip-up">
        <h3 class="text-accent font-bold">36</h3>
        <p>Siswa</p>
      </div>
      <div class="p-4 bg-charcoal-800 rounded-lg" data-aos="flip-up">
        <h3 class="text-accent font-bold">1 Wali Kelas</h3>
        <p>Pembimbing</p>
      </div>
      <div class="p-4 bg-charcoal-800 rounded-lg" data-aos="flip-up">
        <h3 class="text-accent font-bold">2026/2027</h3>
        <p>Tahun Ajaran</p>
      </div>
    </div>
  </section>

  <!-- Daftar Siswa Grid -->
  <section class="py-16 px-4 max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-charcoal-100 mb-8">
      Siswa X RPL 1
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
      {siswa.map((s) => (
        <div
          class="bg-charcoal-800 p-4 rounded-lg text-center"
          data-aos="fade-down"
        >
          <img
            src={s.image ? `${base}/${s.image}` : 'https://placehold.co/800x600/png'}
            alt={s.nama}
            class="w-20 h-20 rounded-full mx-auto object-cover border-2 border-charcoal-600"
          />
          <p class="mt-2 text-charcoal-100 font-medium text-sm">
            {s.nama}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- Foto Kegiatan -->
  <section class="py-16 px-4 max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-charcoal-100 mb-8">
      Momen Kebersamaan
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img
        src={`${base}/momen1.jpg`}
        class="rounded-lg object-cover w-full h-48"
        alt="Kegiatan 1"
      />
      <img
        src={`${base}/momen2.jpg`}
        class="rounded-lg object-cover w-full h-48"
        alt="Kegiatan 2"
      />
      <img
        src={`${base}/momen3.jpg`}
        class="rounded-lg object-cover w-full h-48"
        alt="Kegiatan 3"
      />
    </div>
  </section>

  <!-- Footer / Kontak -->
  <footer class="py-8 bg-charcoal-800 text-center text-charcoal-400">
    <p>
      Hubungi admin:
      <a href="mailto:study@danydevid.my.id">
        <span class="text-accent">study@danydevid.my.id</span>
      </a>
    </p>
    <p class="mt-2 text-sm">
      © 2026 X RPL 1 – SMK Negeri 1 Pasuruan
    </p>
  </footer>
</Layout>